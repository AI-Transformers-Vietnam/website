# Copy to .env for local dev (`netlify dev`). In production, set these in the
# Netlify UI under Site settings > Environment variables. Never commit .env.

# Resend API key for the pitch-apply email function - https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Where pitch applications are emailed (default: aitransformers.vn@gmail.com)
PITCH_NOTIFY_TO=aitransformers.vn@gmail.com

# Sender address. Must be a Resend-verified domain in production.
# Default uses Resend's shared onboarding sender (fine for testing).
PITCH_NOTIFY_FROM=AI Transformers Vietnam <onboarding@resend.dev>
